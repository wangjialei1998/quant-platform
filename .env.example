APP_NAME=Quant Platform
APP_ENV=development
API_PREFIX=/api
CORS_ORIGINS=["http://localhost:5173"]

DATABASE_URL=postgresql+psycopg://quant:quant@postgres:5432/quant
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

TICKFLOW_API_KEY=
STRATEGY_STORAGE_DIR=/app/storage/strategies
SANDBOX_IMAGE=quant-platform-strategy-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=60

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=quant-platform@example.local
SMTP_TO=

DEFAULT_COMMISSION_RATE=0.0003
DEFAULT_STAMP_TAX_RATE=0.001
DEFAULT_SLIPPAGE_RATE=0.0002

